# Gray Horizons Enterprise — Outreach Agent Credentials
# -------------------------------------------------------
# 1. Copy this file and rename it to:   .env
# 2. Fill in your real values below
# 3. NEVER share or commit your .env file

# Your Gmail address (the one you'll send FROM)
SENDER_EMAIL=you@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one (takes ~2 minutes):
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search for "App Passwords" at the top of that page
#   4. Create an app password — select "Mail" and "Windows Computer"
#   5. Google shows you a 16-character password — paste it here (no spaces)
SENDER_APP_PASSWORD=your-16-char-app-password

# The email address where your review digest will be sent
# This can be the same as SENDER_EMAIL or a different inbox you prefer
REVIEW_EMAIL=you@gmail.com

# SMTP settings (defaults work for Gmail — only change if using another provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
