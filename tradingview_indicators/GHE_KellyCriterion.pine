// GHE Kelly Criterion Position Sizer — Gray Horizons Enterprise
// Calculates optimal position size using Kelly Criterion math.
// Shows exact dollar amount and share count to buy based on account size.
// Sell at $19/month on TradingView invite-only.

//@version=5
indicator("GHE Kelly Position Sizer", overlay=false)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
account_size   = input.float(10000, "Account Size ($)",     group="Account", minval=100)
max_risk_pct   = input.float(2.0,   "Max Risk % Per Trade", group="Account", minval=0.1, maxval=100, step=0.1)
win_rate       = input.float(55.0,  "Historical Win Rate %",group="Kelly",   minval=1,   maxval=99)
avg_win_mult   = input.float(1.5,   "Avg Win / Avg Loss",   group="Kelly",   minval=0.1, step=0.1)
kelly_fraction = input.float(0.25,  "Kelly Fraction (0.25 = Quarter Kelly)", group="Kelly", minval=0.1, maxval=1.0, step=0.05)
stop_pct       = input.float(2.0,   "Stop Loss %",          group="Trade",   minval=0.1, step=0.1)
show_table     = input.bool(true,   "Show Position Table",  group="Display")

// ─── KELLY CALCULATIONS ───────────────────────────────────────────────────────
w = win_rate / 100
b = avg_win_mult
kelly_full     = (b * w - (1 - w)) / b
kelly_sized    = kelly_full * kelly_fraction
kelly_capped   = math.max(0, math.min(kelly_sized, max_risk_pct / 100))

// Position sizing
risk_dollars   = account_size * kelly_capped
position_value = risk_dollars / (stop_pct / 100)
shares         = math.floor(position_value / close)
actual_risk    = shares * close * (stop_pct / 100)

// Expected value per trade
ev_per_trade   = account_size * kelly_capped * (avg_win_mult * w - (1 - w))

// ─── PLOTS ────────────────────────────────────────────────────────────────────
plot(kelly_capped * 100, "Kelly % of Account", color=color.blue, linewidth=2)
hline(max_risk_pct, "Max Risk %", color=color.red, linestyle=hline.style_dashed)
hline(0, "Zero", color=color.gray)

// ─── TABLE ────────────────────────────────────────────────────────────────────
if show_table and barstate.islast
    var table t = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 75), border_width=1, border_color=color.new(color.blue, 50))

    table.cell(t, 0, 0, "GHE KELLY SIZER",    text_color=color.new(color.blue, 0), text_size=size.normal, bgcolor=color.new(color.navy, 60))
    table.cell(t, 1, 0, "@$" + str.tostring(math.round(close, 2)), text_color=color.white, text_size=size.normal, bgcolor=color.new(color.navy, 60))

    table.cell(t, 0, 1, "Account Size",        text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 1, "$" + str.tostring(account_size, "#,###"),    text_color=color.white, text_size=size.small)

    table.cell(t, 0, 2, "Kelly %",             text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 2, str.tostring(math.round(kelly_capped * 100, 2)) + "%",
        text_color=kelly_capped > 0 ? color.green : color.red, text_size=size.small)

    table.cell(t, 0, 3, "Risk ($)",            text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 3, "$" + str.tostring(math.round(actual_risk, 2)),
        text_color=color.orange, text_size=size.small)

    table.cell(t, 0, 4, "Position ($)",        text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 4, "$" + str.tostring(math.round(shares * close, 2), "#,###"),
        text_color=color.white, text_size=size.small)

    table.cell(t, 0, 5, "Shares / Units",      text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 5, str.tostring(shares),  text_color=color.yellow, text_size=size.small)

    table.cell(t, 0, 6, "Stop Loss",           text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 6, "$" + str.tostring(math.round(close * (1 - stop_pct/100), 2)),
        text_color=color.red, text_size=size.small)

    table.cell(t, 0, 7, "Target (1.5R)",       text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 7, "$" + str.tostring(math.round(close * (1 + (stop_pct/100) * avg_win_mult), 2)),
        text_color=color.green, text_size=size.small)

    table.cell(t, 0, 8, "Exp Value/Trade",     text_color=color.gray,  text_size=size.small)
    table.cell(t, 1, 8, "$" + str.tostring(math.round(ev_per_trade, 2)),
        text_color=ev_per_trade > 0 ? color.green : color.red, text_size=size.small)
