// GHE Congressional Trade Tracker — Gray Horizons Enterprise
// Detects volume anomalies consistent with pre-disclosure accumulation patterns.
// The only TradingView indicator targeting congressional edge.
//@version=5
indicator("GHE Congressional Trade Tracker", overlay=true, max_labels_count=500)

// ── Inputs ─────────────────────────────────────────────────────────────────
vol_len       = input.int(50,   "Volume Baseline Length (bars)", group="Volume")
surge_mult    = input.float(2.5,"Surge Threshold (x avg vol)",   group="Volume", step=0.1)
quiet_bars    = input.int(5,    "Quiet Accumulation Window",      group="Pattern")
price_flat    = input.float(1.5,"Max Price Move During Quiet (%)",group="Pattern", step=0.1)
confirm_bars  = input.int(3,    "Confirmation Bars After Surge",  group="Pattern")

show_vol_ma   = input.bool(true,  "Show Volume Baseline",         group="Display")
show_labels   = input.bool(true,  "Show Signal Labels",           group="Display")
alert_on      = input.bool(true,  "Enable Alerts",                group="Display")

acc_col       = input.color(color.new(#ff6d00, 0),  "Accumulation Color", group="Display")
surge_col     = input.color(color.new(#e040fb, 0),  "Surge Color",        group="Display")
confirm_col   = input.color(color.new(#00e676, 0),  "Confirmed Color",    group="Display")

// ── Calculations ───────────────────────────────────────────────────────────
vol_ma   = ta.sma(volume, vol_len)
vol_pct  = volume / vol_ma

// Price range over quiet window (measures how flat price was)
hi_quiet = ta.highest(high,  quiet_bars)
lo_quiet = ta.lowest(low,    quiet_bars)
price_range_pct = (hi_quiet - lo_quiet) / lo_quiet * 100

// Quiet accumulation: volume elevated but price flat (smart money buying without moving price)
avg_vol_quiet   = ta.sma(volume, quiet_bars)
quiet_vol_ratio = avg_vol_quiet / vol_ma

is_quiet_accum  = quiet_vol_ratio >= 1.2 and quiet_vol_ratio < surge_mult and price_range_pct <= price_flat

// Volume surge: sudden spike after quiet period
is_surge = volume >= vol_ma * surge_mult

// Confirmation: price closes above recent high after surge
recent_hi       = ta.highest(high[1], confirm_bars)
is_confirmed    = close > recent_hi and is_surge[confirm_bars]

// Combined pattern: quiet accumulation THEN surge
had_quiet_before = ta.barssince(is_quiet_accum) <= quiet_bars + 2
full_signal      = is_surge and had_quiet_before

// ── Plots ──────────────────────────────────────────────────────────────────
// Subtle background shading during accumulation windows
bgcolor(is_quiet_accum ? color.new(acc_col, 92) : na, title="Accumulation Zone")
bgcolor(full_signal    ? color.new(surge_col, 80) : na, title="Surge Signal")
bgcolor(is_confirmed   ? color.new(confirm_col, 80) : na, title="Confirmed")

// Labels
if show_labels
    if is_quiet_accum and not is_quiet_accum[1]
        label.new(bar_index, low - ta.atr(14) * 0.5,
          text="ACC",
          style=label.style_label_up,
          color=color.new(acc_col, 20),
          textcolor=color.white,
          size=size.tiny)

    if full_signal
        label.new(bar_index, high + ta.atr(14),
          text="SURGE\n" + str.tostring(math.round(vol_pct, 1)) + "x",
          style=label.style_label_down,
          color=surge_col,
          textcolor=color.white,
          size=size.small)

    if is_confirmed
        label.new(bar_index, low - ta.atr(14),
          text="CONFIRMED",
          style=label.style_label_up,
          color=confirm_col,
          textcolor=color.black,
          size=size.small)

// Volume ratio line in data window
plot(vol_pct, "Vol vs Baseline (x)", display=display.data_window)
plot(quiet_vol_ratio, "Quiet Accumulation Ratio", display=display.data_window)

// ── Score Table ─────────────────────────────────────────────────────────────
var table st = table.new(position.bottom_left, 2, 5, border_width=1,
  border_color=color.new(color.gray, 70), frame_width=1,
  frame_color=color.new(color.gray, 50))

if barstate.islast
    hc = color.new(#1565c0, 0)
    bc = color.new(#0d1117, 85)
    table.cell(st, 0, 0, "CONGRESSIONAL TRACKER", bgcolor=hc, text_color=color.white, text_size=size.tiny, text_halign=text.align_center)
    table.cell(st, 1, 0, "STATUS",                bgcolor=hc, text_color=color.white, text_size=size.tiny, text_halign=text.align_center)

    table.cell(st, 0, 1, "Vol vs Baseline", bgcolor=bc, text_color=color.white, text_size=size.tiny)
    table.cell(st, 1, 1, str.tostring(vol_pct, "#.##") + "x",
      bgcolor=bc, text_color=vol_pct >= surge_mult ? surge_col : color.gray, text_size=size.tiny)

    table.cell(st, 0, 2, "Quiet Accum", bgcolor=bc, text_color=color.white, text_size=size.tiny)
    table.cell(st, 1, 2, is_quiet_accum ? "ACTIVE" : "no",
      bgcolor=bc, text_color=is_quiet_accum ? acc_col : color.gray, text_size=size.tiny)

    table.cell(st, 0, 3, "Surge Signal", bgcolor=bc, text_color=color.white, text_size=size.tiny)
    table.cell(st, 1, 3, full_signal ? "DETECTED" : "waiting",
      bgcolor=bc, text_color=full_signal ? surge_col : color.gray, text_size=size.tiny)

    table.cell(st, 0, 4, "Confirmed",   bgcolor=bc, text_color=color.white, text_size=size.tiny)
    table.cell(st, 1, 4, is_confirmed ? "YES" : "no",
      bgcolor=bc, text_color=is_confirmed ? confirm_col : color.gray, text_size=size.tiny)

// ── Alerts ─────────────────────────────────────────────────────────────────
if alert_on
    alertcondition(full_signal,   "GHE Congressional Surge",     "Volume surge after accumulation detected — potential pre-disclosure pattern")
    alertcondition(is_confirmed,  "GHE Congressional Confirmed",  "Pattern confirmed — price breakout after accumulation surge")
    alertcondition(is_quiet_accum,"GHE Accumulation Zone",        "Quiet accumulation detected — watch for surge")
