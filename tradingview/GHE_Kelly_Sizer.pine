//@version=5
indicator("GHE Kelly Position Sizer", shorttitle="GHE-KELLY", overlay=false)

account   = input.float(10000, "Account Size ($)")
win_rate  = input.float(0.55,  "Win Rate (0.01 to 0.99)", minval=0.01, maxval=0.99)
avg_win   = input.float(2.0,   "Avg Win (R multiple)")
avg_loss  = input.float(1.0,   "Avg Loss (R multiple)")
stop_pct  = input.float(2.0,   "Stop Loss %") / 100

b           = avg_win / avg_loss
kelly       = win_rate - ((1 - win_rate) / b)
half_kelly  = kelly / 2
risk_amt    = account * half_kelly
shares      = math.round(risk_amt / (close * stop_pct))
dollar_risk = shares * close * stop_pct

var table t = table.new(position.top_right, 2, 7,
     bgcolor      = color.new(color.black, 5),
     border_width = 1,
     border_color = color.gray)

table.cell(t, 0, 0, "GHE KELLY SIZER",
     text_color  = color.white,
     bgcolor     = color.new(color.navy, 0),
     text_halign = text.align_center,
     colspan     = 2)
table.cell(t, 0, 1, "Win Rate",       text_color=color.gray)
table.cell(t, 1, 1, str.tostring(math.round(win_rate * 100, 1)) + "%", text_color=color.white)
table.cell(t, 0, 2, "Kelly %",        text_color=color.gray)
table.cell(t, 1, 2, str.tostring(math.round(kelly * 100, 2)) + "%",      text_color=color.yellow)
table.cell(t, 0, 3, "Half-Kelly %",   text_color=color.gray)
table.cell(t, 1, 3, str.tostring(math.round(half_kelly * 100, 2)) + "%", text_color=color.green)
table.cell(t, 0, 4, "Risk Amount",    text_color=color.gray)
table.cell(t, 1, 4, "$" + str.tostring(math.round(risk_amt, 2)),         text_color=color.white)
table.cell(t, 0, 5, "Share Count",    text_color=color.gray)
table.cell(t, 1, 5, str.tostring(shares) + " shares",                    text_color=color.aqua)
table.cell(t, 0, 6, "Dollar Risk",    text_color=color.gray)
table.cell(t, 1, 6, "$" + str.tostring(math.round(dollar_risk, 2)),      text_color=color.red)

plot(na)
