//@version=5
indicator("GHE Congressional Tracker", shorttitle="GHE-CONG", overlay=false)

lookback      = input.int(10,   "Lookback Window")
vol_thresh    = input.float(2.5,"Volume Anomaly Threshold (x avg)")
quiet_thresh  = input.float(1.5,"Quiet Accumulation Price Move % Max") / 100

vol_avg    = ta.sma(volume, 30)
vol_ratio  = volume / vol_avg
vol_spike  = vol_ratio >= vol_thresh

// Quiet accumulation: huge volume, small price move (institutional masking)
price_move = math.abs(close - open) / open
quiet      = vol_spike and price_move < quiet_thresh

// Sustained elevation over lookback window
elev = 0
for i = 0 to lookback - 1
    if volume[i] > vol_avg[i] * 1.8
        elev += 1
sustained = elev >= 3

score = (vol_spike ? 40 : 0) + (quiet ? 35 : 0) + (sustained ? 25 : 0)

plot(vol_ratio, "Volume Ratio",   color=color.new(color.gray, 40), linewidth=1)
plot(score > 0 ? score / 5 : na, "Pattern Score", color=color.purple, linewidth=2)
hline(vol_thresh, "Anomaly Line", color=color.orange, linestyle=hline.style_dashed)

bgcolor(quiet     ? color.new(color.purple, 80) : na, title="Quiet Accumulation")
bgcolor(quiet and sustained ? color.new(color.blue, 70) : na, title="Full Pattern")

if quiet and not quiet[1]
    label.new(bar_index, vol_ratio,
              text      = "CONG. PATTERN\n" + str.tostring(math.round(vol_ratio, 1)) + "x vol\nScore: " + str.tostring(score),
              color     = color.purple,
              textcolor = color.white,
              style     = label.style_label_up,
              size      = size.small)
