//@version=5
indicator("GHE Edge Scanner", shorttitle="GHE-EDGE", overlay=false)

rsi_len        = input.int(14,   "RSI Length")
vol_mult       = input.float(1.5,"Volume Surge Multiplier")
ema_fast       = input.int(9,    "EMA Fast")
ema_slow       = input.int(21,   "EMA Slow")
threshold      = input.int(70,   "Signal Threshold (0-100)")

// RSI component (0-40 pts)
rsi       = ta.rsi(close, rsi_len)
rsi_bull  = rsi > 50 and rsi < 70
rsi_bear  = rsi < 50 and rsi > 30
rsi_score = rsi_bull ? 40 : rsi_bear ? 20 : 0

// Volume component (0-30 pts)
vol_avg   = ta.sma(volume, 20)
vol_score = volume > vol_avg * vol_mult ? 30 : volume > vol_avg * 1.2 ? 15 : 0

// EMA confluence (0-30 pts)
ema9      = ta.ema(close, ema_fast)
ema21     = ta.ema(close, ema_slow)
ema_bull  = ema9 > ema21 and close > ema9
ema_bear  = ema9 < ema21 and close < ema9
ema_score = ema_bull ? 30 : ema_bear ? 15 : 0

total     = rsi_score + vol_score + ema_score
dir       = rsi_bull and ema_bull ? "LONG" : rsi_bear and ema_bear ? "SHORT" : "NEUTRAL"
signal    = total >= threshold

plot(total, "Edge Score",
     color     = signal ? color.green : color.gray,
     linewidth = 2)
hline(threshold, "Threshold", color=color.orange, linestyle=hline.style_dashed)
hline(0,   "", color=color.gray)
hline(100, "", color=color.gray)

bgcolor(signal ? (dir == "LONG" ? color.new(color.green, 85) : color.new(color.red, 85)) : na)

if signal and not signal[1]
    label.new(bar_index, total,
              text      = dir + "\nScore: " + str.tostring(total),
              color     = dir == "LONG" ? color.green : color.red,
              textcolor = color.white,
              style     = label.style_label_up,
              size      = size.small)
