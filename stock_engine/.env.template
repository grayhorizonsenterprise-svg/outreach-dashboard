# Copy this to .env and fill in your values
# stock_engine/.env

# Phone alerts (free — ntfy.sh)
# 1. Install "ntfy" app on phone
# 2. In app: subscribe to this exact topic name
# 3. Pick something unique so others can't send to your phone
NTFY_TOPIC=grayhorizons_stocks_YOUR_UNIQUE_ID

# Robinhood credentials
RH_USERNAME=your_robinhood_email@gmail.com
RH_PASSWORD=your_robinhood_password
# If you have 2FA enabled, generate TOTP code OR disable 2FA in RH settings
# RH_MFA_CODE=

# Congress trading data (free — quiverquant.com/quiverapi, sign up takes 2 min)
# 100 free requests/day — covers all of Congress including Pelosi
QUIVERQUANT_KEY=

# Optional — enhances sentiment scoring (free tiers)
# newsapi.org: 100 req/day free
NEWS_API_KEY=

# alphavantage.co: 25 req/day free
ALPHA_VANTAGE_KEY=
